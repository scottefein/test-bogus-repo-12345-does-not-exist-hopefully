#!/usr/bin/env bash
# Compile src/agents + src/templates -> .claude/agents for this repo
# Usage: bin/build

set -euo pipefail
source "$(dirname "$0")/_lib.sh"

log "Compiling agents from src/ -> .claude/"

mkdir -p "$AGENTS_OUT"

count=0
for agent in $(list_agents); do
    compile_agent "$agent" "$AGENTS_OUT"

    # Ensure agent-memory directory exists with .gitkeep
    local_memory="$MEMORY_OUT/$agent"
    mkdir -p "$local_memory"
    touch "$local_memory/.gitkeep"

    ok "  $agent"
    count=$((count + 1))
done

log "Compiled $count agents to $AGENTS_OUT"

# Copy MCP config to repo root
if [[ -f "$SRC_DIR/mcp.json" ]]; then
    cp "$SRC_DIR/mcp.json" "$REPO_ROOT/.mcp.json"
    ok "  .mcp.json"
fi
