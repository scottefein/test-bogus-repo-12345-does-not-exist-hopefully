#!/usr/bin/env bash
# Start the Next.js development server
# Usage: bin/dev [--port PORT]
set -euo pipefail

PORT="${1:-3000}"
if [[ "${1:-}" == "--port" ]]; then
    PORT="${2:-3000}"
fi

# Install dependencies if needed
if [[ ! -d node_modules ]]; then
    echo "[dev] Installing dependencies..."
    npm install
fi

# Check if port is in use
if lsof -i :"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
    echo "[dev] Port $PORT is already in use"
    echo "[dev] Run bin/stop to stop the existing server, or use bin/dev --port <other>"
    exit 1
fi

echo "[dev] Starting Next.js dev server on port $PORT..."
npx next dev --port "$PORT" &
DEV_PID=$!

# Save PID for bin/stop
mkdir -p .dev
echo "$DEV_PID" > .dev/pid
echo "$PORT" > .dev/port

echo "[dev] Server started (PID: $DEV_PID)"
echo "[dev] http://localhost:$PORT"
echo "[dev] Run bin/stop to stop the server"

wait "$DEV_PID" 2>/dev/null || true
